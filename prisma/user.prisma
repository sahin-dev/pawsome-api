model User {
    id   Int  @id @default(autoincrement())
    fullName String 
    email   String @unique
    password    String 
    role  UserRole
    last_assigned  DateTime?
    is_blocked    Boolean @default(false)
    is_email_verified Boolean @default(false)
    is_deleted  Boolean @default(false)
    emergency_contact  String?
    addresses Address[]
    pets   Pet[]
    bookings Booking[]
    roomsparticipants Participant[]
    blockList BlockList[] @relation("blocker")
    blockedBy BlockList[] @relation("blocked_by")
    messages_sent Chat[] @relation("sender")
    messages_received Chat[] @relation("recipient")
    location_lat Float?
    location_lng Float?
    is_terms_accepted  Boolean  @default(false)
    terms_accepted_at  DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@map("users")

}


model Address {
    id Int  @id  @default(autoincrement())
    title String
    text     String
    userId  Int
    user User  @relation(fields:[userId], references:[id])
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@map("addresses")
}


enum UserRole {
    USER
    SITTER
    ADMIN
}
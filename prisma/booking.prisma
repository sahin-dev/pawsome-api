model Booking {
    id  Int  @id @default(autoincrement())
    serviceId  Int
    packageId  Int
    startedAt  DateTime
    endedAt   DateTime
    status     BookingStatus @default(Pending)

    createdAt  DateTime  @default(now())
    updatedAt  DateTime @updatedAt

    time      String
    address  String

@@map("bookings")
}

enum BookingStatus {
    Pending 
    Confirmed 
    In_Progress 
    Completed 
    Cancelled 
}
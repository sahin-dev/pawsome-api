model Service {

    id  Int  @id @default(autoincrement())
    title  String
    icon  String?
    description String
    price Float
    duration  Float
    durationUnit DurationUnit
    status  ServiceStatus @default(ACTIVE)
    bookings Booking[]
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

@@map("services")

}

enum  ServiceStatus  {
    ACTIVE
    INACTIVE
}

enum DurationUnit {
    min
    hour
    day
    week
    month
    hr
}